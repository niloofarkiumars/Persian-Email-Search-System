# Elasticsearch Configuration
ES_HOST=https://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=YOUR_PASSWORD_HERE

# MongoDB Configuration
MONGO_HOST=mongodb://localhost:27017/
MONGO_DATABASE=email_db
MONGO_COLLECTION=emails

# Application Configuration
INDEX_NAME=persian_emails
LOG_LEVEL=INFO
BATCH_SIZE=100
SEMANTIC_VECTOR_DIMS=384

# Offline semantic search
# Use "hash" for the built-in local vectorizer.
# Use "sentence_transformer" only with a local model directory.
SEMANTIC_BACKEND=hash
SEMANTIC_MODEL_PATH=
