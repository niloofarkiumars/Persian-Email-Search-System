# Elasticsearch Configuration
ES_HOST=https://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=YOUR_PASSWORD_HERE

# MongoDB Configuration
MONGO_HOST=mongodb://localhost:27017/
MONGO_DATABASE=email_db
MONGO_COLLECTION=emails

# Application Configuration
INDEX_NAME=persian_emails
LOG_LEVEL=INFO
BATCH_SIZE=100
SEMANTIC_VECTOR_DIMS=384

# Offline semantic search
# Default uses the bundled local sentence-transformer model.
# Use "hash" if you want the lightweight built-in fallback instead.
SEMANTIC_BACKEND=sentence_transformer
SEMANTIC_MODEL_PATH=models/paraphrase-multilingual-MiniLM-L12-v2
